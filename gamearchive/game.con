////// FIRE SHIT //////
// action <name> <startframe> <frames> <viewtype> <incvalue> <delay>
action FIRE_SPAWN 0 1 1 0 3
action FIRE_BURN 0 13 1 1 3
define FIRE_SPR 2310

// useractor <type> <picnum> [strength] [action] [move] [moveflag 1] [...] [moveflag N]
useractor 0 FIRE_SPR 0 FIRE_SPAWN
  ifaction FIRE_SPAWN {
    sizeat 255 150
    seta[].yoffset 1750
    seta[].alpha 128

    set FIRE_ACTOR THISACTOR
    action FIRE_BURN
  }
  ifaction FIRE_BURN {

    // Time stops for you I guess
    ifn INGAMEMENU 0 {
      return
    }

    var APLAYER
    set APLAYER 0

    var PX
    var PY
    var PZ

    var CX
    var CY

    getp[APLAYER].posx PX
    getp[APLAYER].posy PY
    getp[APLAYER].posz PZ

    geta[].x CX
    geta[].y CY

    var TX

    set TX PX
    sub TX CX
    div TX 5

    add CX TX
    seta[].x CX

    ifl PY CY
      sub CY 60
    else
      set CY PY

    seta[].y CY
    seta[].z PZ

    // Burn the playa
    ifpdistl 800 {
      addphealth -200
    }
  }
enda


////// KEEPER SHIT //////
action KEEPER_SPAWN 0 1 1 0 3
action KEEPER_STAND 0 1 1 0 3
define KEEPER_SPR 2000
useractor 0 KEEPER_SPR 0 KEEPER_SPAWN
  ifaction KEEPER_SPAWN {
    set KEEPER_ACTOR THISACTOR 
    action KEEPER_STAND
  }
  ifhitspace {
    redefinequote 669 That's not enough. no entry!
    quote 669
  }
enda


////// COFFEE SHIT //////
useractor 0 2469
  ifpdistl RETRIEVEDISTANCE {
    definequote 670 Coffee! Hell Yeah!
    userquote 670
    
    addinventory 0 100
    spawn EXPLOSION2
    quake 32
    palfrom 32 0 64 64
    
    wackplayer
    
    killit
  }
enda
action TRAIL_SPAWN -1046 1 1 0 6
useractor 0 2455 0 TRAIL_SPAWN
  ifaction TRAIL_SPAWN {
  //sizeat 36 36
  
  var CURR_ALPHA
  geta .alpha CURR_ALPHA
  add CURR_ALPHA 6
  seta .alpha CURR_ALPHA
 
  ifg CURR_ALPHA 135 sizeat 36 36 
  ifg CURR_ALPHA 248 killit
  }
enda
appendevent EVENT_EGS
  ifactor 2455 {
    seta .alpha 128
  }
endevent

////// and finally... EVENT SHIT //////
appendevent EVENT_ENTERLEVEL
  set CURSOR_X SCR_W
  set CURSOR_Y SCR_H
  div CURSOR_X 2
  div CURSOR_Y 2

  // Reset money counter
  // set MOOLAH 0

  // Fix camera pos, siigh
  setp[].over_shoulder_on 1

  set cameraclock 0

  set FIRE_ACTOR 0

  set INGAMEMENU 0
endevent

onevent EVENT_PREUPDATEANGLES
  var DELTA_X
  var DELTA_Y

  geti[].q16avel DELTA_X
  geti[].q16horz DELTA_Y

  add CURSOR_X DELTA_X
  sub CURSOR_Y DELTA_Y

  clamp CURSOR_X 0 SCR_W
  clamp CURSOR_Y 0 SCR_H

  seti[].q16horz 0
  seti[].q16avel 0
endevent

onevent EVENT_DISPLAYCROSSHAIR
  setu[].return 1 CURSOR_X
  setu[].return 2 CURSOR_Y
endevent

onevent EVENT_PRESSEDFIRE
  set RETURN -1
endevent

onevent EVENT_CROUCH
  set RETURN -1
endevent


var JUSTCLICKED
appendevent EVENT_PROCESSINPUT
  var INP
  geti[].bits INP
  ifand INP 4 {
    ife JUSTCLICKED 0 {
      set JUSTCLICKED 1
      ifn INGAMEMENU 0
        state menuClick
      else
        state handClick
    }
  }
  else
    ife JUSTCLICKED 1
      set JUSTCLICKED 0

  // Don't move in menus!
  ifn INGAMEMENU 0 {
    seti[].fvel 0
    seti[].svel 0
  }
endevent

// Custom HUD
onevent EVENT_DISPLAYSBAR
  // Menu screen doesn't care
  ifn INGAMEMENU 0 {
    state screenmenu
    set RETURN -1
    return
  }

  var TXTORI
  set TXTORI 0
  or TXTORI 2
  // and TXTORI 256

  var TXTFLG
  set TXTFLG 0
  or TXTFLG 1
  or TXTFLG 4
  // and TXTFLG 262144

  // gametext 2822 0 192 666 0 0 26 0 0 xdim ydim
  redefinequote 666 Loot: $%d/$%d
  
  state getfloorcost
  qsprintf 666 666 MOOLAH RETURN
  screentext 2822 320 16 65536 0 0 666 0 0 TXTORI 0 5 8 0 0 TXTFLG 0 0 xdim ydim

  // Status update on stealing??

  // Fire progress
  var FIREORI 6

  // Player progress
  var PLAYER_X
  getp[].posy PLAYER_X
  xor PLAYER_X 0xFFFFFFFF
  add PLAYER_X 320
  shiftvarr PLAYER_X 8
  rotatesprite PLAYER_X 190 32768 1024 1446 0 0 FIREORI 0 0 xdim ydim

  ifn FIRE_ACTOR 0 {
    var FIRE_SPR
    set FIRE_SPR 2310
    var CLK
    set CLK cameraclock
    shiftvarr CLK 2
    mod CLK 9
    add FIRE_SPR CLK

    var FIRE_X
    geta[FIRE_ACTOR].y FIRE_X
    xor FIRE_X 0xFFFFFFFF
    add FIRE_X 320
    shiftvarr FIRE_X 8
    rotatesprite FIRE_X 200 32768 1024 FIRE_SPR 0 0 FIREORI 0 0 xdim ydim

    // var KEEPER_X
    // geta[KEEPER_ACTOR].y KEEPER_X
    // xor KEEPER_X 0xFFFFFFFF
    // add KEEPER_X 320
    // shiftvarr KEEPER_X 8
    // rotatesprite 320 200 32768 1024 2000 0 0 FIREORI 0 0 xdim ydim

    var FIRE_DIST
    set FIRE_DIST PLAYER_X
    sub FIRE_DIST FIRE_X

    clamp FIRE_DIST 0 32
    xor FIRE_DIST 0xFFFFFFFF
    add FIRE_DIST 33

    setp[].pals_time FIRE_DIST
    setp[].pals 0 63
    setp[].pals 1 15
  }

  // Elevator next level prompt
  var PSECT
  var SECLOW
  getp .cursectnum PSECT
  gets[PSECT].lotag SECLOW

  ife SECLOW 33 {
    set TXTFLG 0
    or TXTFLG 2
    or TXTFLG 4

    redefinequote 671 Press E to go up! ($%d)
    
    state getfloorcost
    
    qsprintf 671 671 RETURN
    screentext 2822 160 100 65536 0 0 671 0 0 TXTORI 0 5 8 0 0 TXTFLG 0 0 xdim ydim
  }

  set RETURN -1
endevent

// Floor based camera angle setting
onevent EVENT_GAME

  // Atm everything here can pause while we're in a menu
  ifn INGAMEMENU 0 {
    terminate
  }

  var APLAYER
  set APLAYER 0

  var PSPRITE
  getp[APLAYER].i PSPRITE

  // We should REALLY be the player past here
  ifn PSPRITE THISACTOR
    terminate;

  var PSECT
  getp[APLAYER].cursectnum PSECT

  var SECLOW
  var SECHI
  gets[PSECT].lotag SECLOW
  gets[PSECT].hitag SECHI

  // Camera turn sector, HITAG is angle
  ife SECLOW 32 {
    var TARGETANG
    var PLANG
    set TARGETANG SECHI
    getp[APLAYER].ang PLANG

    getincangle TARGETANG PLANG TARGETANG

    ifg TARGETANG 100
      set TARGETANG 100
    ifl TARGETANG -100
      set TARGETANG -100

    add TARGETANG PLANG

    setp[APLAYER].ang TARGETANG
  }

  // End level elevator. Open the elevator screen and move the player (?)
  // Depends on if the screen is a level warp or not
  // Note: Disabling this to replace with something less intrusive
  ife SECLOW 33 {
    // Opening the actual game menu is restricted for some ungodly reason, so let's fake it!
    // set INGAMEMENU 1

    // Go to next level!
    state getfloorcost 
    
    ifg MOOLAH RETURN ifhitspace {
      sub MOOLAH RETURN
      add FLOORNUM 1
      startlevel 0 FLOORNUM
    }
  }
  
  // Killing floor
//  ife SECLOW 34 iffloordistl 50 {
//    iffloordistl 1 {
//  
//    } else {
//      addphealth -200
//    }
//  }
endevent
