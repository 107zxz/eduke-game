include con/player.con

////// LEVEL SHIT //////
undefinevolume 1
undefinevolume 2

definevolumename 0 Begin Run

definelevelname 0 0 maps/flr0.map 01:00 01:00 GROUND FLOOR
definelevelname 0 1 maps/flr1.map 01:00 01:00 FLOOR 1
definelevelname 0 2 maps/flr2.map 01:00 01:00 FLOOR 2

undefineskill 0
undefineskill 1
undefineskill 2
undefineskill 3
undefineskill 4

////// SCREEN SHIT //////
var SCR_W 20971520
var SCR_H 13107200

var SCR_W_HALF 10485760
var SCR_H_HALF 6553600
var CURSOR_X
var CURSOR_Y

////// GAMESTATE SHIT //////
var FIRE_ACTOR
var KEEPER_ACTOR

var MOOLAH 0
var FLOORNUM 0

defstate getfloorcost
  set RETURN LEVEL
  add RETURN 1
  mul RETURN 350
ends

////// EXPLOSION SHIT //////
action EXPLOSION_FRAMES 0 20 1 1 2
useractor 0 EXPLOSION2 1 EXPLOSION_FRAMES
  cstat 2050
  sizeto 254 254
  spritepal 21
  fall
 
  var PX
  var PY
  getp .posx PX
  getp .posy PY
  
  seta .x PX
  seta .y PY
  
  ifactioncount 20 killit
enda

////// MENU SHIT //////
// 0 -> No menu
// 1 -> Elevator Menu
var INGAMEMENU

defstate menuClick
  var FLOORCOST
  state getfloorcost
  set FLOORCOST RETURN

  ifl CURSOR_Y SCR_H_HALF {
    set INGAMEMENU 0
    add FLOORNUM 1

    startlevel 0 FLOORNUM
    sub MOOLAH 0
  }
  ifg CURSOR_Y SCR_H_HALF ifg MOOLAH FLOORCOST {
    set INGAMEMENU 0
    add FLOORNUM 2

    startlevel 0 FLOORNUM
    sub MOOLAH FLOORCOST
  }
ends

state screenmenu
  var PANEL_H
  set PANEL_H ydim
  shiftvarr PANEL_H 1

  var PANEL_A_ALPHA 0
  var PANEL_B_ALPHA 0
  set PANEL_A_ALPHA 127
  set PANEL_B_ALPHA 0

  // Important variation: If you can't afford the base floor cost, you go to the secret floor
  var FLOOR_COST 0
  state getfloorcost
  set FLOOR_COST RETURN

  var SECOND_FLOOR_COST 0
  set SECOND_FLOOR_COST FLOOR_COST
  mul SECOND_FLOOR_COST 2

  // Allow highlighting the second floor iff you can afford it
  ifg CURSOR_Y SCR_H_HALF ifg MOOLAH SECOND_FLOOR_COST {
    set PANEL_B_ALPHA 127
    set PANEL_A_ALPHA 0
  }

  // rotatespritea <x> <y> <zoom> <ang> <tilenum> <shade> <pal> <orientation> <alpha> <x1> <y1> <x2> <y2>
  rotatespritea 0 50 65536 0 2456 0 7 1040 PANEL_B_ALPHA 0 0 xdim PANEL_H
  rotatespritea 0 100 65536 0 2456 0 7 1040 PANEL_A_ALPHA 0 0 xdim ydim

  redefinequote 670 floor %d  cost %d  flame speed up
  redefinequote 671 floor %d   cost %d  flame speed up

  // Special: Secret my floor
  ifl MOOLAH FLOOR_COST {
    redefinequote 670 floor S%d  cost 0  oh god the ooze
    redefinequote 671 floor %d  cost %d  flame speed up
  }

  add FLOORNUM 1
  qsprintf 670 670 FLOORNUM FLOOR_COST
  mul FLOOR_COST 2
  add FLOORNUM 1
  qsprintf 671 671 FLOORNUM FLOOR_COST
  sub FLOORNUM 2

  var TEXTFLAGS 0
  set TEXTFLAGS 0
  add TEXTFLAGS 2
  add TEXTFLAGS 8
  add TEXTFLAGS 2097152
  add TEXTFLAGS 8192

  // screentext <tilenum> <x> <y> <zoom> <block angle> <character angle> <quote> <shade> <pal> <orientation> <alpha> <xspace> <yline> <xbetween> <ybetween> <text flags> <x1> <y1> <x2> <y2>
  screentext 2966 160 50 65536 0 0 670 0 0 18 PANEL_B_ALPHA 5 16 0 0 TEXTFLAGS 0 0 xdim ydim
  screentext 2966 160 150 65536 0 0 671 0 0 18 PANEL_A_ALPHA 5 16 0 0 TEXTFLAGS 0 0 xdim ydim

  // Where to?
  definequote 672 where to?
  set TEXTFLAGS 0
  add TEXTFLAGS 2 // Center X
  add TEXTFLAGS 8 // Center Y
  add TEXTFLAGS 8192 // Force Uppercase
  add TEXTFLAGS 1048576 // Bigalphanum
  screentext 2940 160 100 65536 0 0 672 0 0 18 0 5 16 0 0 TEXTFLAGS 0 0 xdim ydim

  // Riches
  redefinequote 673 You have: $%d
  qsprintf 673 673 MOOLAH
  set TEXTFLAGS 0
  add TEXTFLAGS 2 // Center X
  //add TEXTFLAGS 4 // Y Bottom
  add TEXTFLAGS 8192 // Force Uppercase
  add TEXTFLAGS 1048576 // Bigalphanum
  screentext 2940 160 5 65536 0 0 673 0 0 18 0 5 16 0 0 TEXTFLAGS 0 0 xdim ydim

ends


////// GRABBY HAND SHIT //////.

// TODO: See if we can get a trail on this bad they/them

action HAND_SPAWN 0 1 1 0 3
action HAND_GRAHB 0 1 1 0 3
action HAND_RETRC 0 1 1 0 3

define GRABBYHAND 2564 // Temp sprite number
useractor 0 GRABBYHAND 0 HAND_SPAWN
  spriteflags SFLAG_NOCLIP

  ifaction HAND_SPAWN {
    // sound KICK_HIT
    sizeat 30 30
    action HAND_GRAHB
  }
  ifaction HAND_GRAHB {
    var DELTA_X
    var DELTA_Y
    var MY_X
    var MY_Y
    var MY_ANGLE
    var GRABTARGET

    geta[].hitag GRABTARGET

    geta[GRABTARGET].x DELTA_X
    geta[GRABTARGET].y DELTA_Y
    geta[].x MY_X
    geta[].y MY_Y
    sub DELTA_X MY_X
    sub DELTA_Y MY_Y

    var GRABPIC
    geta[GRABTARGET].picnum GRABPIC

    movesprite THISACTOR DELTA_X DELTA_Y 0 0 RETURN

    var DELTA_DIST
    calchypotenuse DELTA_DIST DELTA_X DELTA_Y

    ifl DELTA_DIST 250 {
      // quote 9
      ife GRABPIC 132 {
        var SW_LOWER
        geta[GRABTARGET].lotag SW_LOWER
        seta[GRABTARGET].picnum 133
        operateactivators SW_LOWER 0
        // sound SWITCH_ON
      }
      ife GRABPIC 133 {
        var SW_LOWER
        geta[GRABTARGET].lotag SW_LOWER
        seta[GRABTARGET].picnum 132
        operateactivators SW_LOWER 0
        // sound SWITCH_ON
      }

      action HAND_RETRC
    }
  }
  ifaction HAND_RETRC {
    var DELTA_X
    var DELTA_Y
    var MY_X
    var MY_Y
    var MY_ANGLE

    var APLAYER
    findplayer APLAYER

    var GRABTARGET
    var GRABPIC
    geta[].hitag GRABTARGET
    geta[GRABTARGET].picnum GRABPIC

    // Special case: If it's a switch we *REALLY* don't want to pull it back

    getp[].posx DELTA_X
    getp[].posy DELTA_Y
    geta[].x MY_X
    geta[].y MY_Y
    sub DELTA_X MY_X
    sub DELTA_Y MY_Y

    movesprite THISACTOR DELTA_X DELTA_Y 0 0 RETURN
    // Move the target

    ifn GRABPIC 132 ifn GRABPIC 133 {
      seta[GRABTARGET].x MY_X
      seta[GRABTARGET].y MY_Y
    }


    // Returned to player
    ifl DELTA_X 500 ifg DELTA_X -500 {
      ifl DELTA_Y 500 ifg DELTA_Y -500 {

        ifn GRABPIC 132 ifn GRABPIC 133 {
          changespritestat GRABTARGET 1
          // Special case for coffee, don't delete
          ifn GRABPIC 2469
            seta[GRABTARGET].xrepeat 0
        }

        // Chair
        ife GRABPIC CHAIR1 {
          add MOOLAH 30            
          definequote 680 Stole chair, yoink! ($30)
          userquote 680
          money 10
        }
        // Pipe
        ife GRABPIC PIPE5B {
          add MOOLAH 50
          definequote 681 Stole pipe, heavy! ($50)
          userquote 681
          money 10
        }
        // "Horse"
        ife GRABPIC WOODENHORSE {
          add MOOLAH 20
          definequote 682 Stole barricade, illegal! ($20)
          userquote 682
          money 10
        }
        // Painting
        ife GRABPIC 1075 {
          add MOOLAH 600
          definequote 683 Stole Mona Lisa, Hell yeah! ($600)
          userquote 683
          money 20
        }
        // Bottle
        ife GRABPIC BOTTLE3 {
          add MOOLAH 40
          definequote 684 Stole Beer, but I don't drink! ($40)
          userquote 684
          money 10
        }
        
        killit
      }
    }
  }
enda

defstate handClick
  // Dear god don't let dead people do this
  var PDEAD
  getp[THISACTOR].dead_flag PDEAD

  ifn PDEAD 0
    terminate

  var MY_X
  var MY_Y
  var MY_Z
  var MY_SECTOR
  var MY_COS
  var MY_SIN
  var MY_ZDIST
  var HITSECTOR
  var HITWALL
  var HITSPRITE
  var HITX
  var HITY
  var HITZ
  var MY_ANGLE

  set MY_ANGLE cameraang
  getp[THISACTOR].horiz MY_ZDIST
  subvar MY_ZDIST 100
  mulvar MY_ZDIST -2048

  // Offset the angle by crosshair positioning
  var ANGLE_OFFSET 0
  var FOV
  getu[THISACTOR].fov FOV

  // TODO: Shove in an arctan here (sigmoid function) to fix hitscan

  set ANGLE_OFFSET CURSOR_X
  sub ANGLE_OFFSET SCR_W_HALF
  shiftvarr ANGLE_OFFSET 16

  // Magic numbers, I got these on a calculator and they suck.
  scalevar ANGLE_OFFSET ANGLE_OFFSET 80 50

  add MY_ANGLE ANGLE_OFFSET

	cos MY_COS MY_ANGLE
	sin MY_SIN MY_ANGLE

  var PZ
  getp[THISACTOR].posz PZ

  whilevarl PZ 4000 {
    // This is useful for detecting items directly. Consider for only grabbing valid stuff
    
    // Set up the clipmask
    // clipmask=(sprite_cstat*65536)+wall_cstat
    var CLIPMASK 0
    set CLIPMASK 256
    mul CLIPMASK 65536
    
    hitscan camerax cameray PZ camerasect MY_COS MY_SIN MY_ZDIST HITSECTOR HITWALL HITSPRITE HITX HITY HITZ CLIPMASK
    ifn HITSPRITE -1 {
      var PX
      var PY
      var DELTA_X
      var DELTA_Y
      geta[HITSPRITE].x DELTA_X
      geta[HITSPRITE].y DELTA_Y
      geta[].x PX
      geta[].y PY
      
      // Special condition: Require the hitscan bit to be set

      sub DELTA_X PX
      sub DELTA_Y PY

      getangle MY_ANGLE DELTA_X DELTA_Y

      // Make the target non-colliding if its not a switch
      var GRABPIC
      geta[HITSPRITE].picnum GRABPIC
      ifn GRABPIC 132 ifn GRABPIC 133
        seta[HITSPRITE].cstat 0

      espawn GRABBYHAND
      seta[RETURN].hitag HITSPRITE
      exit
    }
    add PZ 1000
  }

  set RETURN -1
ends


